{
  "title": "FxFlow HTTP Traffic",
  "uid": "fxflow-http-traffic",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "요청수 (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"fxflow\"}[1m]))",
          "legendFormat": "total req/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "응답시간 (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"fxflow\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"fxflow\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "상태코드별 비율 (2xx/4xx/5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"fxflow\", status=~\"2..\"}[1m]))",
          "legendFormat": "2xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"fxflow\", status=~\"4..\"}[1m]))",
          "legendFormat": "4xx",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"fxflow\", status=~\"5..\"}[1m]))",
          "legendFormat": "5xx",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "엔드포인트별 요청수 Top 10",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "expr": "topk(10, sum by (uri, method) (http_server_requests_seconds_count{application=\"fxflow\"}))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  }
}
